# Copy this file to .env and add your actual API keys
# DO NOT commit .env to version control!
# On server: create .env file in /var/www/tergov/.env

# -------------------------------------------------------
# OpenRouter API Key (text + vision + image generation)
# Get from: https://openrouter.ai/keys
# Supports: Gemini, GPT-4, Claude, DALL-E and 200+ models
# -------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# -------------------------------------------------------
# Groq API Key (ultra-fast audio transcription via Whisper)
# Get from: https://console.groq.com/keys  (FREE tier available)
# -------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here

# -------------------------------------------------------
# Login credentials (optional, defaults shown if not set)
# -------------------------------------------------------
LOGIN_USER=admin
LOGIN_PASSWORD=123
